{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "get ai ok",
  "version": "0.1.0",
  "identifier": "com.getaiok.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "get ai ok",
        "width": 420,
        "height": 620,
        "minWidth": 380,
        "minHeight": 520,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
